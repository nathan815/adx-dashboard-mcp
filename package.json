{
  "name": "adx-live-edit-mcp",
  "version": "0.1.0",
  "description": "stdio MCP server for live-editing Azure Data Explorer dashboards in an open browser tab via a Chrome extension and a localhost daemon.",
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "adx-live-edit-mcp": "src/index.js"
  },
  "files": [
    "src",
    "daemon",
    "shared",
    "chrome-extension",
    "docs",
    "README.md"
  ],
  "scripts": {
    "start": "node src/index.js",
    "daemon": "node daemon/agent-server.js",
    "test": "node --test"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "zod": "^3.23.8"
  }
}
